# LLM Provider — pick one: openrouter | openai | mock
LLM_PROVIDER=openrouter

# OpenRouter (use when LLM_PROVIDER=openrouter)
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=qwen/qwen3-8b

# OpenAI (use when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Jina AI — embeddings (free, get key at jina.ai)
JINA_API_KEY=jina_...
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIM=1024

# Pipeline tuning
CONFIDENCE_THRESHOLD=0.45
RETRIEVE_TOP_K=4

# PostgreSQL (pgvector/pgvector:pg16)
DB_NAME=rastad_db
DB_USER=rastad
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
