# LLM Provider — pick one: openrouter | openai | mock
LLM_PROVIDER=openrouter

# OpenRouter (use when LLM_PROVIDER=openrouter)
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=qwen/qwen3-8b

# OpenAI (use when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Embedding Provider — pick one: huggingface | jina | mock
EMBEDDING_PROVIDER=huggingface

# HuggingFace (default — free, get key at huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_...
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# Jina AI (alternative — use when EMBEDDING_PROVIDER=jina)
# JINA_API_KEY=jina_...
# EMBEDDING_MODEL=jina-embeddings-v3
# EMBEDDING_DIM=1024

# Pipeline tuning
CONFIDENCE_THRESHOLD=0.45
RETRIEVE_TOP_K=4

# PostgreSQL (pgvector/pgvector:pg16)
DB_NAME=rastad_db
DB_USER=rastad
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5433

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
